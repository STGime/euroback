# Eurobase Console — SvelteKit build
# Node.js adapter for server-side rendering

FROM node:22-alpine AS builder
WORKDIR /app
COPY console/package*.json ./
RUN npm ci
COPY console/ .
ENV PUBLIC_API_URL=https://api.eurobase.app
RUN npm run build

FROM node:22-alpine
WORKDIR /app
COPY --from=builder /app/build ./build
COPY --from=builder /app/package.json .
ENV PORT=3000
ENV ORIGIN=https://console.eurobase.app
EXPOSE 3000
CMD ["node", "build/index.js"]
