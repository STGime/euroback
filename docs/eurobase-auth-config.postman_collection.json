		{
			"name": "Phase 2 — auth_config enforcement on end-user auth",
			"description": "These tests verify that the auth_config set via PATCH is enforced on end-user sign-up and sign-in via the SDK routes.\n\nPrerequisite: Run the Eurobase Auth Tests collection first to set `public_key` in the Eurobase Local environment.",
			"item": [
				{
					"name": "T2.0 Setup — Set password_min_length=12, session=1h",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('password_min_length is 12', () => {",
									"    pm.expect(pm.response.json().auth_config.password_min_length).to.eql(12);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"auth_config\": {\n    \"providers\": { \"email_password\": { \"enabled\": true } },\n    \"password_min_length\": 12,\n    \"require_email_confirmation\": false,\n    \"session_duration\": \"1h\",\n    \"redirect_urls\": [\"http://localhost:3000\"]\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tenants/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants", "{{project_id}}"]
						}
					}
				},
				{
					"name": "T2.1 End-user sign-up — rejected (password too short for config)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 400', () => pm.response.to.have.status(400));",
									"pm.test('Error mentions 12 characters', () => {",
									"    pm.expect(pm.response.json().error).to.include('12');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"shortpwd@test.eu\",\n  \"password\": \"only8chr\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/signup",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "signup"]
						}
					}
				},
				{
					"name": "T2.2 End-user sign-up — success (password meets 12-char minimum)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 201', () => pm.response.to.have.status(201));",
									"pm.test('Token expires_in is 3600 (1h session)', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.expires_in).to.eql(3600);",
									"    pm.expect(json.access_token).to.be.a('string');",
									"    pm.expect(json.user.email).to.eql('configtest@test.eu');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"configtest@test.eu\",\n  \"password\": \"longpassword12\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/signup",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "signup"]
						}
					}
				},
				{
					"name": "T2.3 Setup — Disable email_password provider",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 400 — no providers enabled', () => {",
									"    pm.response.to.have.status(400);",
									"    pm.expect(pm.response.json().error).to.include('provider');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"auth_config\": {\n    \"providers\": { \"email_password\": { \"enabled\": false } },\n    \"password_min_length\": 8,\n    \"require_email_confirmation\": false,\n    \"session_duration\": \"168h\",\n    \"redirect_urls\": [\"http://localhost:3000\"]\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tenants/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants", "{{project_id}}"]
						}
					}
				},
				{
					"name": "T2.4 Verify auth_config in GET projects list",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Project list items have auth_config', () => {",
									"    const projects = pm.response.json();",
									"    pm.expect(projects).to.be.an('array');",
									"    // Find our project",
									"    const p = projects.find(x => x.id === pm.collectionVariables.get('project_id'));",
									"    if (p && p.auth_config) {",
									"        pm.expect(p.auth_config.password_min_length).to.be.a('number');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/tenants",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants"]
						}
					}
				},
