						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Reset to defaults', () => {",
									"    const cfg = pm.response.json().auth_config;",
									"    pm.expect(cfg.password_min_length).to.eql(8);",
									"    pm.expect(cfg.session_duration).to.eql('168h');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"auth_config\": {\n    \"providers\": { \"email_password\": { \"enabled\": true } },\n    \"password_min_length\": 8,\n    \"require_email_confirmation\": false,\n    \"session_duration\": \"168h\",\n    \"redirect_urls\": [\"http://localhost:3000\"]\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tenants/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants", "{{project_id}}"]
						}
					}
				}
			]
