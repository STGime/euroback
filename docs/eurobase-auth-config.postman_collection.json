									"pm.test('session_duration is 720h', () => {",
									"    pm.expect(pm.response.json().auth_config.session_duration).to.eql('720h');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"auth_config\": {\n    \"providers\": { \"email_password\": { \"enabled\": true } },\n    \"password_min_length\": 8,\n    \"require_email_confirmation\": false,\n    \"session_duration\": \"720h\",\n    \"redirect_urls\": [\"http://localhost:3000\"]\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tenants/{{project_id}}",
