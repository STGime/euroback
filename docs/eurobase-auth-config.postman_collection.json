{
	"info": {
		"name": "Eurobase Auth Config (PATCH /v1/tenants/{id})",
		"description": "Tests for the auth_config PATCH endpoint and its enforcement on end-user auth.\n\nPrerequisites:\n1. Gateway running: `DEV_MODE=true source .env.local && go run ./cmd/gateway/`\n2. A project already created (set `project_id` and `public_key` variables from Phase 1 collection)\n3. Select the \"Eurobase Local\" environment\n\nRun tests in order — later tests depend on variables set by earlier ones.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080"
		},
		{
			"key": "auth_token",
			"value": "dev",
			"description": "Any value works in dev mode"
		},
		{
			"key": "project_id",
			"value": "",
			"description": "Set to an existing project ID"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{auth_token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Phase 1 — PATCH /v1/tenants/{id} (auth_config)",
			"item": [
				{
					"name": "T1.1 Update auth_config — valid defaults",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Response contains auth_config', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.auth_config).to.be.an('object');",
									"    pm.expect(json.auth_config.providers.email_password.enabled).to.eql(true);",
									"    pm.expect(json.auth_config.password_min_length).to.eql(8);",
									"    pm.expect(json.auth_config.session_duration).to.eql('168h');",
									"    pm.expect(json.auth_config.require_email_confirmation).to.eql(false);",
									"    pm.expect(json.auth_config.redirect_urls).to.include('http://localhost:3000');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"auth_config\": {\n    \"providers\": { \"email_password\": { \"enabled\": true } },\n    \"password_min_length\": 8,\n    \"require_email_confirmation\": false,\n    \"session_duration\": \"168h\",\n    \"redirect_urls\": [\"http://localhost:3000\"]\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tenants/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants", "{{project_id}}"]
						}
					}
				},
				{
					"name": "T1.2 Update auth_config — custom settings",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Custom values persisted', () => {",
									"    const cfg = pm.response.json().auth_config;",
									"    pm.expect(cfg.password_min_length).to.eql(12);",
									"    pm.expect(cfg.session_duration).to.eql('24h');",
									"    pm.expect(cfg.require_email_confirmation).to.eql(true);",
									"    pm.expect(cfg.redirect_urls).to.have.lengthOf(2);",
