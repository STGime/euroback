				{
					"name": "T2.7 Token Refresh",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('New tokens issued', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.access_token).to.be.a('string');",
									"    pm.expect(json.refresh_token).to.be.a('string');",
									"    // New refresh token should differ from old one",
									"    pm.expect(json.refresh_token).to.not.eql(pm.environment.get('alice_refresh'));",
									"    pm.environment.set('alice_token', json.access_token);",
									"    pm.environment.set('alice_refresh_old', pm.environment.get('alice_refresh'));",
									"    pm.environment.set('alice_refresh', json.refresh_token);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
