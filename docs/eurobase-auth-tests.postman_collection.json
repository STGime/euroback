		{
			"name": "Phase 1 — API Key Validation",
			"item": [
				{
					"name": "T1.1 Create Project",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 201', () => pm.response.to.have.status(201));",
									"pm.test('Has API keys', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.public_key).to.match(/^eb_pk_/);",
									"    pm.expect(json.secret_key).to.match(/^eb_sk_/);",
									"    pm.expect(json.id).to.be.a('string');",
									"    pm.expect(json.status).to.eql('active');",
									"    pm.environment.set('project_id', json.id);",
									"    pm.environment.set('public_key', json.public_key);",
									"    pm.environment.set('secret_key', json.secret_key);",
									"});"
								],
