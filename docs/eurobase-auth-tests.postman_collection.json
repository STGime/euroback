{
	"info": {
		"name": "Eurobase Auth Tests",
		"description": "Manual testing collection for per-project end-user authentication.\n\nRun tests in order — later tests depend on variables set by earlier ones.\n\n## Setup\n\n1. `make setup` — start Postgres, Redis, MinIO\n2. Apply migrations: `source .env.local && migrate -path migrations -database \"$DATABASE_URL\" up`\n3. Start gateway with auth enforced: `export DEV_MODE=false && source .env.local && go run ./cmd/gateway/`\n4. Select the \"Eurobase Local\" environment in Postman",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [],
	"item": [
		{
			"name": "Phase 0 — Platform Auth",
			"item": [
				{
					"name": "T0.1 Platform Sign Up",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const status = pm.response.code;",
									"pm.test('Status is 201 or 400 (already exists)', () => {",
									"    pm.expect(status).to.be.oneOf([201, 400]);",
									"});",
									"if (status === 201) {",
									"    pm.test('Has access_token', () => {",
									"        const json = pm.response.json();",
									"        pm.expect(json.access_token).to.be.a('string');",
									"        pm.expect(json.token_type).to.eql('bearer');",
									"        pm.expect(json.expires_in).to.eql(86400);",
									"        pm.expect(json.user.email).to.eql('dev@test.eu');",
									"        pm.environment.set('platform_token', json.access_token);",
									"        pm.environment.set('platform_user_id', json.user.id);",
									"    });",
									"} else {",
									"    pm.test('Already registered — will sign in next', () => {",
									"        pm.expect(pm.response.json().error).to.include('already');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"dev@test.eu\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/platform/auth/signup",
							"host": ["{{base_url}}"],
							"path": ["platform", "auth", "signup"]
						}
					}
				},
