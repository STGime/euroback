		{
			"name": "Phase 6 — End-to-End Token Flow (Manual)",
			"description": "These tests require extracting tokens from gateway logs. Run forgot-password, then find the raw token in the log output (\"email not configured, logging instead\" message) and paste it into E6.1.\n\nAlternatively, query the DB: SELECT encode(decode(token_hash, 'hex'), 'hex') ... — but the raw token is only in the log.",
			"item": [
				{
					"name": "E6.1 Platform Reset Password — With Real Token (manual)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// This test requires a real token extracted from gateway logs.",
									"// If using a dummy token, expect 400.",
									"const status = pm.response.code;",
									"pm.test('Status is 200 (real token) or 400 (dummy)', () => {",
									"    pm.expect(status).to.be.oneOf([200, 400]);",
									"});",
									"if (status === 200) {",
									"    pm.test('Password reset succeeded', () => {",
									"        pm.expect(pm.response.json().status).to.eql('ok');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
