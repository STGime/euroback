		{
			"name": "Phase 5 — Email Templates (Platform)",
			"item": [
				{
					"name": "E5.1 List Email Templates",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Returns array of 4 templates', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.be.an('array');",
									"    pm.expect(json.length).to.eql(4);",
									"    const types = json.map(t => t.template_type).sort();",
									"    pm.expect(types).to.deep.eql(['password_changed', 'password_reset', 'verification', 'welcome']);",
									"});",
									"pm.test('All defaults are not custom', () => {",
									"    const json = pm.response.json();",
									"    json.forEach(t => {",
									"        pm.expect(t.is_custom).to.eql(false);",
									"        pm.expect(t.subject).to.be.a('string').and.not.empty;",
									"        pm.expect(t.body_html).to.be.a('string').and.not.empty;",
									"    });",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/email-templates",
							"host": ["{{base_url}}"],
							"path": ["platform", "projects", "{{project_id}}", "email-templates"]
