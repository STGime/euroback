{
	"info": {
		"name": "Eurobase OAuth Social Login",
		"description": "Tests for OAuth social login endpoints (Google, GitHub).\n\n## Setup\n\n1. Gateway running: `source .env.local && go run ./cmd/gateway/`\n2. Migration 021 applied\n3. `platform_token`, `project_id`, `public_key` set\n\n## Note\n\nOAuth flows require real Google/GitHub credentials and a browser. These tests verify the API endpoints respond correctly without actual OAuth credentials configured. Full end-to-end OAuth testing requires:\n1. A Google Cloud OAuth app (or GitHub OAuth app) with valid credentials\n2. Credentials configured in the project's auth_config\n3. A browser for the consent flow",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [],
	"item": [
		{
			"name": "Phase 1 — OAuth Redirect (No Credentials)",
			"item": [
				{
					"name": "O1.1 Google redirect — provider not configured",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 400', () => pm.response.to.have.status(400));",
									"pm.test('Error mentions not enabled', () => {",
									"    pm.expect(pm.response.json().error).to.include('not enabled');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/auth/oauth/google?redirect_url=http://localhost:3000/callback",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "oauth", "google"],
							"query": [{ "key": "redirect_url", "value": "http://localhost:3000/callback" }]
						}
					}
				},
				{
					"name": "O1.2 GitHub redirect — provider not configured",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 400', () => pm.response.to.have.status(400));",
									"pm.test('Error mentions not enabled', () => {",
									"    pm.expect(pm.response.json().error).to.include('not enabled');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/auth/oauth/github?redirect_url=http://localhost:3000/callback",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "oauth", "github"],
							"query": [{ "key": "redirect_url", "value": "http://localhost:3000/callback" }]
						}
					}
				},
				{
					"name": "O1.3 Unknown provider",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 400', () => pm.response.to.have.status(400));",
									"pm.test('Error mentions unknown', () => {",
									"    pm.expect(pm.response.json().error.toLowerCase()).to.include('unknown');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/auth/oauth/facebook?redirect_url=http://localhost:3000/callback",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "oauth", "facebook"],
							"query": [{ "key": "redirect_url", "value": "http://localhost:3000/callback" }]
						}
					}
				},
				{
					"name": "O1.4 Missing redirect_url",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 400', () => pm.response.to.have.status(400));",
									"pm.test('Error mentions redirect', () => {",
									"    pm.expect(pm.response.json().error.toLowerCase()).to.include('redirect');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/auth/oauth/google",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "oauth", "google"]
						}
					}
				},
				{
					"name": "O1.5 No API key",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 401', () => pm.response.to.have.status(401));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/auth/oauth/google?redirect_url=http://localhost:3000",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "oauth", "google"],
							"query": [{ "key": "redirect_url", "value": "http://localhost:3000" }]
						}
					}
				}
			]
		},
		{
			"name": "Phase 2 — OAuth Callback (Invalid Code)",
			"item": [
				{
					"name": "O2.1 Google callback — invalid code",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Without OAuth configured, this should return an error",
									"pm.test('Status is 400 or 302', () => {",
									"    pm.expect(pm.response.code).to.be.oneOf([400, 302]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/auth/oauth/google/callback?code=invalid_code&state=invalid_state",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "oauth", "google", "callback"],
							"query": [
								{ "key": "code", "value": "invalid_code" },
								{ "key": "state", "value": "invalid_state" }
							]
						}
					}
				},
				{
					"name": "O2.2 Callback — missing code",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 400', () => pm.response.to.have.status(400));",
									"pm.test('Error mentions code', () => {",
									"    pm.expect(pm.response.json().error.toLowerCase()).to.include('code');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/auth/oauth/google/callback?state=test",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "oauth", "google", "callback"],
							"query": [{ "key": "state", "value": "test" }]
						}
					}
				},
				{
					"name": "O2.3 Callback — missing state",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 400', () => pm.response.to.have.status(400));",
									"pm.test('Error mentions state', () => {",
									"    pm.expect(pm.response.json().error.toLowerCase()).to.include('state');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/auth/oauth/google/callback?code=test",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "oauth", "google", "callback"],
							"query": [{ "key": "code", "value": "test" }]
						}
					}
				}
			]
		},
		{
			"name": "Phase 3 — Auth Config with OAuth",
			"item": [
				{
					"name": "O3.1 Save auth config with Google OAuth",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Config saved', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.auth_config).to.exist;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"auth_config\": {\n    \"providers\": { \"email_password\": { \"enabled\": true } },\n    \"oauth_providers\": {\n      \"google\": { \"enabled\": true, \"client_id\": \"test-client-id\", \"client_secret\": \"test-client-secret\" },\n      \"github\": { \"enabled\": false, \"client_id\": \"\", \"client_secret\": \"\" }\n    },\n    \"password_min_length\": 8,\n    \"require_email_confirmation\": false,\n    \"session_duration\": \"168h\",\n    \"redirect_urls\": [\"http://localhost:3000\"]\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tenants/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants", "{{project_id}}"]
						}
					}
				},
				{
					"name": "O3.2 Google redirect — now configured (test credentials)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// With test credentials, should redirect to Google (302)",
									"// Or return the redirect URL if following redirects is disabled",
									"pm.test('Status is 302 or 200', () => {",
									"    pm.expect(pm.response.code).to.be.oneOf([302, 200, 400]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/auth/oauth/google?redirect_url=http://localhost:3000",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "oauth", "google"],
							"query": [{ "key": "redirect_url", "value": "http://localhost:3000" }]
						}
					}
				},
				{
					"name": "O3.3 Reset auth config (remove test credentials)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"auth_config\": {\n    \"providers\": { \"email_password\": { \"enabled\": true } },\n    \"oauth_providers\": {},\n    \"password_min_length\": 8,\n    \"require_email_confirmation\": false,\n    \"session_duration\": \"168h\",\n    \"redirect_urls\": [\"http://localhost:3000\"]\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tenants/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants", "{{project_id}}"]
						}
					}
				}
			]
		}
	]
}
