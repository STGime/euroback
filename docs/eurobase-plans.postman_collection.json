{
	"info": {
		"name": "Eurobase Plan Limits & Usage",
		"description": "Tests for plan limits enforcement, usage tracking, and plan-gated features.\n\n## Setup\n\n1. `make setup` — start Postgres, Redis, MinIO\n2. Apply migrations including 000017: `source .env.local && migrate -path migrations -database \"$DATABASE_URL\" up`\n3. Start gateway: `source .env.local && go run ./cmd/gateway/`\n4. Select the \"Eurobase Local\" environment in Postman\n5. Run Phase 0 from the auth-tests collection first to set `platform_token` and `project_id`\n\n## Test order\n\nRun phases in order. Phase 3 (webhook limit) requires a clean project with <3 webhooks.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [],
	"item": [
		{
			"name": "Phase 1 — Plans & Usage Endpoints",
			"item": [
				{
					"name": "P1.1 Get All Plans",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Returns array with free and pro plans', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.be.an('array');",
									"    pm.expect(json.length).to.be.at.least(2);",
									"    const names = json.map(p => p.plan).sort();",
									"    pm.expect(names).to.include('free');",
									"    pm.expect(names).to.include('pro');",
									"});",
									"pm.test('Free plan has correct limits', () => {",
									"    const free = pm.response.json().find(p => p.plan === 'free');",
									"    pm.expect(free.db_size_mb).to.eql(500);",
									"    pm.expect(free.storage_mb).to.eql(1024);",
									"    pm.expect(free.mau_limit).to.eql(10000);",
									"    pm.expect(free.rate_limit_rps).to.eql(100);",
									"    pm.expect(free.project_limit).to.eql(2);",
									"    pm.expect(free.webhook_limit).to.eql(3);",
									"    pm.expect(free.custom_templates).to.eql(false);",
									"});",
									"pm.test('Pro plan has correct limits', () => {",
									"    const pro = pm.response.json().find(p => p.plan === 'pro');",
									"    pm.expect(pro.db_size_mb).to.eql(5120);",
									"    pm.expect(pro.storage_mb).to.eql(51200);",
									"    pm.expect(pro.mau_limit).to.eql(100000);",
									"    pm.expect(pro.rate_limit_rps).to.eql(1000);",
									"    pm.expect(pro.project_limit).to.eql(10);",
									"    pm.expect(pro.webhook_limit).to.eql(0);",
									"    pm.expect(pro.custom_templates).to.eql(true);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/platform/config/plans",
							"host": ["{{base_url}}"],
							"path": ["platform", "config", "plans"]
						}
					}
				},
				{
					"name": "P1.2 Get Project Usage",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Has usage and limits objects', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('usage');",
									"    pm.expect(json).to.have.property('limits');",
									"});",
									"pm.test('Usage has expected fields', () => {",
									"    const u = pm.response.json().usage;",
									"    pm.expect(u).to.have.property('database_size_mb');",
									"    pm.expect(u).to.have.property('storage_size_mb');",
									"    pm.expect(u).to.have.property('mau_count');",
									"    pm.expect(u).to.have.property('webhook_count');",
									"    pm.expect(u).to.have.property('project_count');",
									"});",
									"pm.test('Limits match free plan', () => {",
									"    const l = pm.response.json().limits;",
									"    pm.expect(l.plan).to.eql('free');",
									"    pm.expect(l.db_size_mb).to.eql(500);",
									"    pm.expect(l.project_limit).to.eql(2);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/usage",
							"host": ["{{base_url}}"],
							"path": ["platform", "projects", "{{project_id}}", "usage"]
						}
					}
				},
				{
					"name": "P1.3 Plans — No Auth",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 401', () => pm.response.to.have.status(401));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/platform/config/plans",
							"host": ["{{base_url}}"],
							"path": ["platform", "config", "plans"]
						}
					}
				},
				{
					"name": "P1.4 Usage — No Auth",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 401', () => pm.response.to.have.status(401));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/usage",
							"host": ["{{base_url}}"],
							"path": ["platform", "projects", "{{project_id}}", "usage"]
						}
					}
				}
			]
		},
		{
			"name": "Phase 2 — Custom Templates Gate (Free Plan)",
			"item": [
				{
					"name": "P2.1 Update Email Template — Free Plan (should fail)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 403', () => pm.response.to.have.status(403));",
									"pm.test('Error mentions upgrade to pro', () => {",
									"    pm.expect(pm.response.json().error).to.include('pro');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"subject\": \"Custom subject\",\n  \"body_html\": \"<p>Custom body</p>\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/email-templates/verification",
							"host": ["{{base_url}}"],
							"path": ["platform", "projects", "{{project_id}}", "email-templates", "verification"]
						}
					}
				},
				{
					"name": "P2.2 List Templates — Still Works (read is not gated)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Returns 4 default templates', () => {",
									"    pm.expect(pm.response.json().length).to.eql(4);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/email-templates",
							"host": ["{{base_url}}"],
							"path": ["platform", "projects", "{{project_id}}", "email-templates"]
						}
					}
				}
			]
		},
		{
			"name": "Phase 3 — Webhook Limit (Free Plan = 3)",
			"item": [
				{
					"name": "P3.1 Create Webhook 1",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 201', () => pm.response.to.have.status(201));",
									"pm.test('Webhook created', () => {",
									"    pm.expect(pm.response.json().url).to.eql('https://example.com/hook1');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://example.com/hook1\",\n  \"events\": [\"insert\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/webhooks",
							"host": ["{{base_url}}"],
							"path": ["platform", "projects", "{{project_id}}", "webhooks"]
						}
					}
				},
				{
					"name": "P3.2 Create Webhook 2",
					"event": [
						{
							"listen": "test",
							"script": {
