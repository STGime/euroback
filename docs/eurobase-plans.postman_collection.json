		},
		{
			"name": "Phase 4 — Project Limit (Free Plan = 2)",
			"description": "The free plan allows max 2 projects. If you already have 2 projects, creating a 3rd should fail.\n\nNote: This test depends on how many projects you already have. If you only have 1 project, P4.1 will succeed (creating the 2nd). P4.2 tests the 3rd which should fail.",
			"item": [
				{
					"name": "P4.1 Create 2nd Project (should succeed if only 1 exists)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const status = pm.response.code;",
									"pm.test('Status is 201 or 403', () => {",
									"    pm.expect(status).to.be.oneOf([201, 403]);",
									"});",
									"if (status === 201) {",
									"    pm.test('Project created', () => {",
									"        pm.environment.set('second_project_id', pm.response.json().id);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"plan-limit-test\",\n  \"slug\": \"plan-limit-test\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tenants",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants"]
						}
					}
				},
				{
					"name": "P4.2 Create 3rd Project — Should Fail (limit = 2)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 403', () => pm.response.to.have.status(403));",
									"pm.test('Error mentions project limit', () => {",
									"    const body = pm.response.json();",
									"    pm.expect(body.error).to.include('project');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"should-fail\",\n  \"slug\": \"should-fail\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tenants",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants"]
						}
					}
				}
			]
		},
		{
			"name": "Phase 5 — Rate Limiting with Plan",
			"description": "The free plan allows 100 req/s. This is hard to trigger in Postman manually but verifies the headers are returned correctly.",
			"item": [
				{
					"name": "P5.1 API Request Returns Rate Limit Headers",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Rate limit headers present', () => {",
									"    pm.expect(pm.response.headers.get('X-RateLimit-Limit')).to.exist;",
									"    pm.expect(pm.response.headers.get('X-RateLimit-Remaining')).to.exist;",
									"    pm.expect(pm.response.headers.get('X-RateLimit-Reset')).to.exist;",
									"});",
									"pm.test('Rate limit matches free plan (100)', () => {",
									"    pm.expect(pm.response.headers.get('X-RateLimit-Limit')).to.eql('100');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "apikey", "value": "{{public_key}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/db/todos",
							"host": ["{{base_url}}"],
							"path": ["v1", "db", "todos"]
						}
					}
				}
			]
		},
		{
			"name": "Phase 6 — Cleanup",
			"description": "Delete test webhooks and the second project created during testing.",
			"item": [
				{
					"name": "P6.1 List Webhooks (get IDs for cleanup)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"const webhooks = pm.response.json();",
									"if (webhooks.length > 0) {",
									"    pm.environment.set('cleanup_webhook_ids', JSON.stringify(webhooks.map(w => w.id)));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/webhooks",
							"host": ["{{base_url}}"],
							"path": ["platform", "projects", "{{project_id}}", "webhooks"]
						}
					}
				},
				{
					"name": "P6.2 Delete 2nd Project (if created)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// OK if 200/204 or 404 (wasn't created)",
									"pm.test('Cleanup OK', () => {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 204, 404]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/v1/tenants/{{second_project_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "tenants", "{{second_project_id}}"]
						}
					}
				}
			]
		}
	]
}
