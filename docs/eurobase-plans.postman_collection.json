						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://example.com/hook3\",\n  \"events\": [\"insert\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/webhooks",
