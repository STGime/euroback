{
	"info": {
		"name": "Eurobase Sprint 1 — Data API Features",
		"description": "Tests for aggregations, full-text search, nested relation selects, and usage dashboard.\n\n## Setup\n\n1. Gateway running: `source .env.local && go run ./cmd/gateway/`\n2. Migrations applied (through 017)\n3. Select \"Eurobase Local\" environment\n4. Run Phase 0 from auth-tests collection to set `platform_token`, `project_id`, `public_key`\n5. The project needs a `todos` table with data (created by default on project provisioning)\n\n## Test data setup\n\nSome tests require a second table with a foreign key. Run the \"Setup\" phase first to create test data.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [],
	"item": [
		{
			"name": "Phase 0 — Setup Test Data",
			"item": [
				{
					"name": "S0.1 Create 'categories' table",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const status = pm.response.code;",
									"pm.test('Status is 201 or 400 (already exists)', () => {",
									"    pm.expect(status).to.be.oneOf([201, 400]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"categories\",\n  \"columns\": [\n    { \"name\": \"id\", \"type\": \"uuid\", \"nullable\": false, \"is_primary_key\": true, \"default_value\": \"uuid_generate_v4()\" },\n    { \"name\": \"name\", \"type\": \"text\", \"nullable\": false, \"is_primary_key\": false },\n    { \"name\": \"created_at\", \"type\": \"timestamptz\", \"nullable\": false, \"is_primary_key\": false, \"default_value\": \"now()\" }\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/schema/tables",
							"host": ["{{base_url}}"],
							"path": ["platform", "projects", "{{project_id}}", "schema", "tables"]
						}
					}
				},
				{
					"name": "S0.2 Create 'posts' table with FK to categories",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const status = pm.response.code;",
									"pm.test('Status is 201 or 400 (already exists)', () => {",
									"    pm.expect(status).to.be.oneOf([201, 400]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{platform_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"posts\",\n  \"columns\": [\n    { \"name\": \"id\", \"type\": \"uuid\", \"nullable\": false, \"is_primary_key\": true, \"default_value\": \"uuid_generate_v4()\" },\n    { \"name\": \"title\", \"type\": \"text\", \"nullable\": false, \"is_primary_key\": false },\n    { \"name\": \"body\", \"type\": \"text\", \"nullable\": true, \"is_primary_key\": false },\n    { \"name\": \"category_id\", \"type\": \"uuid\", \"nullable\": true, \"is_primary_key\": false, \"foreign_key\": { \"column\": \"category_id\", \"referenced_table\": \"categories\", \"referenced_column\": \"id\", \"on_delete\": \"SET NULL\" } },\n    { \"name\": \"created_at\", \"type\": \"timestamptz\", \"nullable\": false, \"is_primary_key\": false, \"default_value\": \"now()\" }\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/platform/projects/{{project_id}}/schema/tables",
							"host": ["{{base_url}}"],
							"path": ["platform", "projects", "{{project_id}}", "schema", "tables"]
						}
					}
				},
				{
					"name": "S0.3 Insert categories",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 201', () => pm.response.to.have.status(201));",
									"pm.environment.set('category_id', pm.response.json().id);"
								],
								"type": "text/javascript"
							}
